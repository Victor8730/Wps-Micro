{
  "name": "webpagestudio/wps-micro",
  "description": "Lightweight PHP framework for building web applications",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Victor Galiuzov",
      "email": "victor8730@gmail.com"
    }
  ],
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": "^8.3",
    "twig/twig": "^3.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "psr/container": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "WpsMicro\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpsMicro\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  },
  "archive": {
    "exclude": [
      "**/.DS_Store",
      "/.github/",
      "/.idea/",
      "/.phpunit.cache/",
      "/composer.lock",
      "/phpunit.xml.dist",
      "/tests/",
      "/vendor/"
    ]
  }
}

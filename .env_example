APP_NAME="WPS Micro"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

ROUTER_DEFAULT_CONTROLLER=home
ROUTER_DEFAULT_ACTION=index

TWIG_VIEWS_PATH=application/Views
TWIG_CACHE_PATH=application/Cache
TWIG_AUTO_RELOAD=true
TWIG_AUTOESCAPE=html

DB_DRIVER=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_FORWARD_PORT=3307
DB_ROOT_PASSWORD=root
DB_DATABASE=wps_micro
DB_USERNAME=wps_micro
DB_PASSWORD=secret
DB_CHARSET=utf8mb4

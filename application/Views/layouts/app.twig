<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="WPS Micro application">
    <meta name="author" content="Victor Galiuzov">
    <link rel="icon" href="{{ asset('img/favicon.ico') }}">
    <title>{% block title %}WPS Micro{% endblock %}</title>
    {{ vite('resources/js/app.js') }}
</head>
<body class="min-h-full bg-zinc-50 font-sans text-zinc-950 antialiased">
<div class="flex min-h-screen flex-col">
    <header class="border-b border-zinc-200 bg-white">
        <nav class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8"
             aria-label="Main navigation">
            <a href="{{ url('/') }}" class="shrink-0 text-lg font-semibold text-zinc-950 hover:text-brand-700">
                WPS Micro
            </a>

            <div class="flex min-w-0 items-center gap-2 sm:gap-3">
                {% if auth_user is defined and auth_user %}
                    <div class="hidden min-w-0 text-right md:block">
                        <p class="truncate text-sm font-medium text-zinc-900">{{ auth_user.name }}</p>
                        <p class="truncate text-xs text-zinc-500">{{ auth_user.email }}</p>
                    </div>
                    <a href="{{ url('/account') }}"
                       class="inline-flex min-h-9 items-center justify-center rounded-lg border border-zinc-300 px-3 text-sm font-medium text-zinc-700 transition hover:border-zinc-400 hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
                        Account
                    </a>
                    <form action="{{ url('/logout') }}" method="post">
                        {{ csrf_field() }}
                        <button type="submit"
                                class="inline-flex min-h-9 items-center justify-center rounded-lg bg-zinc-900 px-3 text-sm font-medium text-white transition hover:bg-zinc-700 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2">
                            Log out
                        </button>
                    </form>
                {% else %}
                    <a href="{{ url('/login') }}"
                       class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 text-sm font-medium text-zinc-700 transition hover:bg-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
                        Log in
                    </a>
                    <a href="{{ url('/register') }}"
                       class="inline-flex min-h-9 items-center justify-center rounded-lg bg-brand-600 px-3 text-sm font-medium text-white transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
                        Create account
                    </a>
                {% endif %}
            </div>
        </nav>
    </header>

    <main class="flex-1">
        <div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
            <a href="{{ url('/') }}" class="mx-auto mb-10 block w-full max-w-sm" aria-label="WPS Micro home">
                <img class="h-auto w-full" src="{{ asset('img/logo.png') }}" alt="WPS Micro" width="500" height="86">
            </a>

            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="border-t border-zinc-200 bg-white">
        <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-6 text-sm text-zinc-500 sm:px-6 lg:px-8">
            <p>&copy; {{ "now"|date("Y") }} Webpagestudio</p>
            <a href="{{ url('/') }}" class="font-medium text-zinc-600 hover:text-brand-700">Home</a>
        </div>
    </footer>
</div>
</body>
</html>

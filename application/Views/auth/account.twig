{% extends "layouts/app.twig" %}

{% block title %}Account | WPS Micro{% endblock %}

{% block content %}
    <div class="mx-auto w-full max-w-2xl">
        {% set success_message = flash('success') %}
        {% if success_message %}
            <div class="mb-5 rounded-lg border border-brand-100 bg-brand-50 px-4 py-3 text-sm text-brand-700" role="status">
                {{ success_message }}
            </div>
        {% endif %}

        <section class="overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex items-start justify-between gap-4 border-b border-zinc-200 px-5 py-5 sm:px-6">
                <div class="min-w-0">
                    <p class="text-sm font-medium text-brand-700">Authenticated account</p>
                    <h1 class="mt-1 truncate text-2xl font-semibold text-zinc-950">{{ auth_user.name }}</h1>
                </div>
                <span class="shrink-0 rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">Signed in</span>
            </div>

            <dl class="divide-y divide-zinc-200">
                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-zinc-500">User ID</dt>
                    <dd class="text-sm text-zinc-950 sm:col-span-2">{{ auth_user.id }}</dd>
                </div>

                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-zinc-500">Email</dt>
                    <dd class="break-all text-sm text-zinc-950 sm:col-span-2">{{ auth_user.email }}</dd>
                </div>

                <div class="grid gap-1 px-5 py-4 sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-zinc-500">Created</dt>
                    <dd class="text-sm text-zinc-950 sm:col-span-2">{{ auth_user.created_at }}</dd>
                </div>
            </dl>
        </section>
    </div>
{% endblock %}

{% extends "example-template.twig" %}

{% block title %}Log in | WPS Micro{% endblock %}

{% block content %}
    <div class="col-md-7 col-lg-5">
        {% set success_message = flash('success') %}
        {% if success_message %}
            <div class="alert alert-success" role="alert">{{ success_message }}</div>
        {% endif %}

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-4">Log in</h1>

                <form action="{{ url('/login') }}" method="post" class="needs-validation" novalidate>
                    {{ csrf_field() }}

                    <div class="form-group">
                        <label for="email">Email address</label>
                        <input
                            type="email"
                            class="form-control{% if error('email') %} is-invalid{% endif %}"
                            id="email"
                            name="email"
                            value="{{ old('email') }}"
                            autocomplete="email"
                            required
                            autofocus
                        >
                        {% if error('email') %}
                            <div class="invalid-feedback">{{ error('email') }}</div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input
                            type="password"
                            class="form-control{% if error('password') %} is-invalid{% endif %}"
                            id="password"
                            name="password"
                            autocomplete="current-password"
                            minlength="8"
                            required
                        >
                        {% if error('password') %}
                            <div class="invalid-feedback">{{ error('password') }}</div>
                        {% endif %}
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">Log in</button>
                </form>

                <p class="text-muted text-center mt-4 mb-0">
                    No account yet? <a href="{{ url('/register') }}">Create one</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}

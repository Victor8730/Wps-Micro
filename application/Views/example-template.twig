<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="WPS Micro application">
    <meta name="author" content="Victor Galiuzov">
    <link rel="icon" href="{{ asset('img/favicon.ico') }}">
    <title>{% block title %}WPS Micro{% endblock %}</title>
    <link href="{{ asset('css/bootstrap.css') }}" rel="stylesheet">
    <link href="{{ asset('css/form-validation.css') }}" rel="stylesheet">
    <link href="{{ asset('css/font-awesome.css') }}" rel="stylesheet">
    <link href="{{ asset('css/style.css') }}" rel="stylesheet">
</head>
<body class="bg-light">
<header>
    <nav class="navbar navbar-expand navbar-dark bg-dark box-shadow">
        <div class="container">
            <a href="{{ url('/') }}" class="navbar-brand font-weight-bold">WPS Micro</a>
            <div class="ml-auto d-flex align-items-center">
                {% if auth_user is defined and auth_user %}
                    <span class="navbar-text mr-3 d-none d-md-inline">
                        {{ auth_user.name }} &middot; {{ auth_user.email }}
                    </span>
                    <a href="{{ url('/account') }}" class="btn btn-outline-light btn-sm mr-2">Account</a>
                    <form action="{{ url('/logout') }}" method="post" class="m-0">
                        {{ csrf_field() }}
                        <button type="submit" class="btn btn-light btn-sm">Log out</button>
                    </form>
                {% else %}
                    <a href="{{ url('/login') }}" class="btn btn-outline-light btn-sm mr-2">Log in</a>
                    <a href="{{ url('/register') }}" class="btn btn-light btn-sm">Create account</a>
                {% endif %}
            </div>
        </div>
    </nav>
</header>
<main class="container py-5">
    <div class="text-center mb-5">
        <a href="{{ url('/') }}">
            <img class="img-fluid" src="{{ asset('img/logo.png') }}" alt="WPS Micro" width="500" height="86">
        </a>
    </div>

    <div class="row content justify-content-center">
        {% block content %}
        {% endblock %}
    </div>
</main>

<footer class="container pb-5 text-muted text-center text-small">
    <p class="mb-2">&copy; {{ "now"|date("Y") }} Webpagestudio</p>
    <a href="{{ url('/') }}" class="text-info">Home</a>
</footer>

<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.bundle.js') }}"></script>
<script>
    /**
     * Enable native Bootstrap form validation styles.
     */
    (function () {
        'use strict';
        window.addEventListener('load', function () {
            let forms = document.getElementsByClassName('needs-validation');
            Array.prototype.filter.call(forms, function (form) {
                form.addEventListener('submit', function (event) {
                    if (form.checkValidity() === false) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        }, false);
    })();

    $(function () {
        $('[data-toggle="tooltip"],.tooltip-show').tooltip({'placement': 'bottom'});
    });
</script>
</body>
</html>

{% extends "example-template.twig" %}
{% block title %}Home | WPS Micro{% endblock %}
{% block content %}
    <div class="col-md-12 order-md-2">
        {% if auth_user is defined and auth_user %}
            <div class="alert alert-success d-flex justify-content-between align-items-center">
                <div>
                    Signed in as <strong>{{ auth_user.name }}</strong> ({{ auth_user.email }}).
                </div>
                <a href="{{ url('/account') }}" class="btn btn-sm btn-success">View account</a>
            </div>
        {% endif %}
        <div class="card text-center">
            <form action="/" method="post" class="my-2 form">
                {{ csrf_field() }}
                <div class="input-group px-4 py-2">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fa fa-bars pr-2" aria-hidden="true"></i>Select example</span>
                    </div>
                    <select name="type-redirect" class="form-control">
                        <option value="1">option 1</option>
                        <option value="2">option 2</option>
                    </select>
                </div>
                <div class="input-group px-4 py-2">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fa fa-share-alt pr-2" aria-hidden="true"></i>Input example</span>
                    </div>
                    <input type="text" name="url-data" id="url-data" class="form-control" placeholder="placeholder example" aria-describedby="url-data">
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 py-2">
                        <button type="submit" class="btn btn-success tooltip-show" title="Creating kml file">Example button</button>
                    </div>
                </div>
            </form>
        </div>
        {% if messages is defined and messages %}
            <section class="mt-4 text-left">
                <h2>Stored messages</h2>
                {% for message in messages %}
                    <article class="mb-3">
                        <h3>{{ message.title }}</h3>
                        <p>{{ message.body }}</p>
                    </article>
                {% endfor %}
            </section>
        {% endif %}
    </div>
{% endblock %}

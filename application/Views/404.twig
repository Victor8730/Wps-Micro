{% extends "layouts/app.twig" %}

{% block title %}Page not found | WPS Micro{% endblock %}
{% block content %}
    <div class="mx-auto w-full max-w-2xl text-center">
        <p class="text-sm font-semibold text-brand-700">404</p>
        <h1 class="mt-2 text-3xl font-semibold text-zinc-950">Page not found</h1>
        <p class="mx-auto mt-3 max-w-lg leading-7 text-zinc-600">The page may have moved, or the address may be incorrect.</p>
        <img src="{{ asset('img/404.jpg') }}" alt="Page not found" class="mx-auto mt-7 h-auto w-full max-w-xl rounded-lg border border-zinc-200">
        <a href="{{ url('/') }}"
           class="mt-7 inline-flex min-h-10 items-center justify-center rounded-lg bg-brand-600 px-4 text-sm font-semibold text-white transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
            Return home
        </a>
    </div>
{% endblock %}

APP_NAME="WPS Micro"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com

SESSION_NAME=WPSMICROSESSID
SESSION_LIFETIME=0
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

LOG_PATH=application/Cache/app.log

TWIG_VIEWS_PATH=application/Views
TWIG_CACHE_PATH=application/Cache
TWIG_AUTO_RELOAD=false
TWIG_AUTOESCAPE=html

DB_DRIVER=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=wps_micro
DB_USERNAME=wps_micro
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4
DB_MIGRATIONS_PATH=application/Database/migrations
